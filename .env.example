# TikHub（必填，搜索 / 评论 / 笔记接口）
# 大陆走 .dev，海外走 .io
TIKHUB_API_KEY=
TIKHUB_BASE=https://api.tikhub.dev

# LLM（仅 selector.py --analyze 时需要；默认走阿里千问）
# 申请：https://bailian.console.aliyun.com → API-KEY 管理
DASHSCOPE_API_KEY=

# 可选：换模型（qwen-turbo / qwen-plus / qwen-max / qwen3-235b-a22b 等）。不填走 qwen-plus
LLM_MODEL=

# 可选：换 OpenAI 兼容的其他厂商（DeepSeek / 智谱 / Kimi 等）。不填走 DashScope
# 例：LLM_BASE_URL=https://api.deepseek.com/v1
LLM_BASE_URL=
